{
  "name": "Meilisearch JS",
  "entryPoints": ["./src/index.ts", "./src/token.ts"],
  "readme": "none",
  "out": "./docs/api",
  "docsRoot": "./docs",
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"],
  "sidebar": {
    "autoConfiguration": true,
    "format": "vitepress",
    "pretty": true,
    "collapsed": false
  },
  "groupOrder": [
    "References",
    "Modules",
    "Namespaces",
    "Enumerations",
    "Enumeration Members",
    "Classes",
    "Interfaces",
    "Type Aliases",
    "Constructors",
    "Properties",
    "Variables",
    "Functions",
    "Accessors",
    "Methods"
  ],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "navigationLinks": {
    "Docs": "https://www.meilisearch.com/docs",
    "GitHub": "https://github.com/meilisearch/meilisearch-js"
  }
}
