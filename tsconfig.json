{
  "compilerOptions": {
    "noEmit": true,
    // We don't want to check node_modules
    "skipLibCheck": true,
    "module": "node20",
    // Node.js 20 at https://node.green/#ES2023
    "target": "es2023",
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  }
}
